# ===========================================
# Intel Briefing - 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填入你的 API Key

# GitHub Token (用于 GitHub Trending 等)
GITHUB_TOKEN=ghp_your_github_token_here

# X/Grok API (用于 Twitter/X 舆情分析)
XAI_API_KEY=sk-your_grok_api_key_here
# ⚠️ 以下默认值对齐 .github/workflows/daily-report.yml
XAI_BASE_URL=https://api.x.ai/v1/chat/completions
XAI_MODEL=grok-4-fast

# Product Hunt API (官方 API Token)
PRODUCTHUNT_TOKEN=your_product_hunt_token_here

# ===========================================
# LLM 配置 (OpenAI-compatible API)
# ===========================================
# 用于翻译、摘要生成等中文文本处理
LLM_API_KEY=sk-your_packyapi_key_here
LLM_API_URL=https://api-slb.packyapi.com/v1
LLM_MODEL=qwen3.5-flash

# OpenAI API (如果使用 OpenAI 作为 LLM)
# OPENAI_API_KEY=sk-your_openai_key_here

